{
  "name": "spendsync-backend",
  "version": "1.0.0",
  "description": "SpendSync Expense Tracker Backend API with Better Auth",
  "keywords": [
    "expense-tracker",
    "better-auth",
    "postgresql",
    "typescript"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "install:deps": "powershell -ExecutionPolicy Bypass -File ./install-deps.ps1",
    "install:deps:sh": "sh ./install-deps.sh"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "drizzle-kit": "^0.24.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.33.0",
    "next": "^16.2.10",
    "postgres": "^3.4.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  }
}
